# Dunst Notification Configuration - Majestic Purple Theme
[global]
    monitor = 0
    follow = mouse
    width = 300
    height = 120
    origin = top-right
    offset = 20x50
    scale = 1
    notification_limit = 4
    
    # Progress bar styling
    progress_bar = true
    progress_bar_height = 6
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    
    # Geometry and borders
    frame_width = 2
    frame_color = "#b380f7"
    separator_color = frame
    corner_radius = 10
    
    # Text and Fonts
    font = FiraCode Nerd Font 9
    line_height = 3
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    show_age_threshold = 60
    
    # Icons
    enable_recursive_icon_lookup = true
    icon_position = left
    min_icon_size = 32
    max_icon_size = 48
    
    # Behavior
    history_length = 20
    dmenu = /usr/bin/rofi -dmenu -p dunst:
    browser = /usr/bin/firefox -new-tab
    always_run_script = true
    title = Dunst
    class = Dunst
    
[urgency_low]
    background = "#100b19"
    foreground = "#ebd9fc"
    timeout = 5
    override_variables = true

[urgency_normal]
    background = "#1b122c"
    foreground = "#ebd9fc"
    timeout = 8
    override_variables = true

[urgency_critical]
    background = "#ff6688"
    foreground = "#ebd9fc"
    frame_color = "#ff5555"
    timeout = 0
    override_variables = true
